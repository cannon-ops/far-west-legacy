# Far West Legacy — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Anthropic API (BYOK — user supplies their own key)
ANTHROPIC_API_KEY=sk-ant-...

# FamilySearch OAuth 2.0
# Register your app at https://developers.familysearch.org
FAMILYSEARCH_CLIENT_ID=
FAMILYSEARCH_CLIENT_SECRET=
FAMILYSEARCH_REDIRECT_URI=http://localhost:8080/callback

# Environment: integration (sandbox) or production
# Use integration until Compatibility Review is passed
FAMILYSEARCH_ENV=integration
