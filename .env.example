# Far West Legacy — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Anthropic API (BYOK — user supplies their own key)
ANTHROPIC_API_KEY=sk-ant-...

# FamilySearch OAuth 2.0
# Register your app at https://developers.familysearch.org
FAMILYSEARCH_CLIENT_ID=
FAMILYSEARCH_CLIENT_SECRET=
FAMILYSEARCH_REDIRECT_URI=http://localhost:8081/callback

# Environment: beta (development) or production
# Use beta until Compatibility Review is passed
FAMILYSEARCH_ENV=beta

# Flask session signing key
# REQUIRED in production (set in Render dashboard). May stay unset locally —
# src/app.py falls back to a dev-only placeholder if FLASK_SECRET_KEY is missing.
FLASK_SECRET_KEY=
